{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth?route=:path*"
    },
    {
      "source": "/api/admin/:path*",
      "destination": "/api/admin?route=:path*"
    },
    {
      "source": "/api/health",
      "destination": "/api/shop?route=health"
    },
    {
      "source": "/api/products",
      "destination": "/api/shop?route=products"
    },
    {
      "source": "/api/products/:id",
      "destination": "/api/shop?route=products&id=:id"
    },
    {
      "source": "/api/categories",
      "destination": "/api/shop?route=categories"
    },
    {
      "source": "/api/categories/:id",
      "destination": "/api/shop?route=categories&id=:id"
    },
    {
      "source": "/api/currencies",
      "destination": "/api/shop?route=currencies"
    },
    {
      "source": "/api/orders/:path*",
      "destination": "/api/shop?route=orders&subpath=:path*"
    },
    {
      "source": "/api/cart/:path*",
      "destination": "/api/shop?route=cart&subpath=:path*"
    },
    {
      "source": "/api/crypto-wallets",
      "destination": "/api/shop?route=crypto-wallets"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "trailingSlash": false
}