{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/categories",
      "destination": "/api/shop?route=categories"
    },
    {
      "source": "/api/products",
      "destination": "/api/shop?route=products"
    },
    {
      "source": "/api/health",
      "destination": "/api/shop?route=health"
    },
    {
      "source": "/api/cart",
      "destination": "/api/customer?route=cart"
    },
    {
      "source": "/api/orders",
      "destination": "/api/customer?route=orders"
    },
    {
      "source": "/api/currencies",
      "destination": "/api/customer?route=currencies"
    },
    {
      "source": "/api/crypto-wallets",
      "destination": "/api/customer?route=crypto-wallets"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "/api/auth?route=:path*"
    },
    {
      "source": "/api/admin/:path*",
      "destination": "/api/admin?route=:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "trailingSlash": false
}